{
  "name": "spec-while",
  "version": "1.0.0",
  "packageManager": "pnpm@10.32.1",
  "description": "Git-first task orchestrator for Spec Kit workspaces",
  "author": "Zhang Yu",
  "license": "ISC",
  "homepage": "https://github.com/zhangyu1818/spec-while#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhangyu1818/spec-while.git"
  },
  "bugs": {
    "url": "https://github.com/zhangyu1818/spec-while/issues"
  },
  "keywords": [
    "spec-kit",
    "spec-driven",
    "task-orchestrator",
    "cli",
    "git"
  ],
  "bin": {
    "spec-while": "./bin/spec-while.mjs"
  },
  "files": [
    "LICENSE",
    "README.md",
    "REQUIREMENT.md",
    "bin",
    "src"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "smoke:codex": "tsx fixtures/smoke/codex-provider.ts",
    "smoke:e2e:codex": "tsx fixtures/smoke/codex-e2e.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.116.0",
    "arg": "^5.0.2",
    "tsx": "^4.21.0",
    "zod": "3.25.76",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "4.1.0",
    "@zhangyu1818/eslint-config": "^5.0.0",
    "eslint": "^10.1.0",
    "typescript": "^5.9.3",
    "vitest": "4.1.0"
  }
}
